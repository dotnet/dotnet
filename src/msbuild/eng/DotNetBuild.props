<!-- When altering this file, include @dotnet/product-construction as a reviewer. -->
<Project>

  <PropertyGroup Condition="'$(DotNetBuildSourceOnly)' == 'true'">
    <!-- Filter down projects aggressively in source-only modes. -->
    <BuildArgs>$(BuildArgs) /p:Projects="$(ProjectDirectory)MSBuild.SourceBuild.slnf"</BuildArgs>

    <!-- Disable package validation as source build filters out target frameworks. -->
    <BuildArgs>$(BuildArgs) /p:EnablePackageValidation=false</BuildArgs>
  </PropertyGroup>

</Project>

    <PatchVersion>15</PatchVersion>
    <PreReleaseVersionLabel>servicing</PreReleaseVersionLabel>
    <PreReleaseVersionIteration>
    </PreReleaseVersionIteration>
    <!-- Enable to remove prerelease label. -->

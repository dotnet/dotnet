<Project>

  <UsingTask TaskName="Microsoft.NET.Build.Tasks.PickBestRid" AssemblyFile="$(MicrosoftNETBuildTasksAssembly)" />

  <PropertyGroup>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('linux')) and '$(TargetArchitecture)' == 'x64'">linux-x64</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('linux')) and '$(TargetArchitecture)' == 'arm'">linux-arm</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('linux')) and '$(TargetArchitecture)' == 'arm64'">linux-arm64</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('win')) and '$(TargetArchitecture)' == 'x64'">win-x64</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('win')) and '$(TargetArchitecture)' == 'x86'">win-x86</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('win')) and '$(TargetArchitecture)' == 'arm64'">win-arm64</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('osx')) and '$(TargetArchitecture)' == 'x64'">osx-x64</DotnetUserSecretsPackageRid>
    <DotnetUserSecretsPackageRid Condition="'$(DotnetUserSecretsPackageRid)' == '' and '$(DotNetBuildSourceOnly)' != 'true' and $(ProductMonikerRid.StartsWith('osx')) and '$(TargetArchitecture)' == 'arm64'">osx-arm64</DotnetUserSecretsPackageRid>
  </PropertyGroup>

  <ItemGroup Condition="'$(IncludeAspNetCoreRuntime)' != 'false'">
    <BundledDotnetTool Include="dotnet-dev-certs" Version="$(DotnetDevCertsPackageVersion)" />
    <BundledDotnetTool Include="dotnet-user-jwts" Version="$(DotnetUserJwtsPackageVersion)" />
    <BundledDotnetTool Include="dotnet-user-secrets" Version="$(DotnetUserSecretsPackageVersion)" ObsoletesCliTool="Microsoft.Extensions.SecretManager.Tools">
      <RidSpecificPackageRuntimeIdentifiers>linux-x64;linux-arm;linux-arm64;win-x64;win-x86;win-arm64;osx-x64;osx-arm64</RidSpecificPackageRuntimeIdentifiers>
      <RidSpecificPackageId Condition="'$(DotnetUserSecretsPackageRid)' != ''">dotnet-user-secrets.$(DotnetUserSecretsPackageRid)</RidSpecificPackageId>
    </BundledDotnetTool>
  </ItemGroup>

  <ItemGroup>
    <BundledDotnetTool Update="@(BundledDotnetTool)">
      <PackageIdToRestore>%(Identity)</PackageIdToRestore>
      <PackageIdToRestore Condition="'%(RidSpecificPackageId)' != ''">%(RidSpecificPackageId)</PackageIdToRestore>
    </BundledDotnetTool>
  </ItemGroup>

  <ItemGroup>
    <BundledDotnetTool Update="@(BundledDotnetTool)">
      <PackagePathRelativeToPackageRoot>%(PackageIdToRestore)/%(Version)/</PackagePathRelativeToPackageRoot>
      <NupkgPathRelativeToPackageRoot>%(PackageIdToRestore)/%(Version)/%(PackageIdToRestore).%(Version).nupkg</NupkgPathRelativeToPackageRoot>
    </BundledDotnetTool>
  </ItemGroup>

  <ItemGroup>
    <BundledDotnetTool Update="@(BundledDotnetTool)">
      <RestoredPackagePath>$(NuGetPackageRoot)$([MSBuild]::ValueOrDefault('%(PackagePathRelativeToPackageRoot)', '').ToLowerInvariant())/</RestoredPackagePath>
      <RestoredNupkgPath>$(NuGetPackageRoot)$([MSBuild]::ValueOrDefault('%(NupkgPathRelativeToPackageRoot)', '').ToLowerInvariant())</RestoredNupkgPath>
    </BundledDotnetTool>
  </ItemGroup>

  <ItemGroup>
    <PackageDownload Include="%(BundledDotnetTool.PackageIdToRestore)" Version="[%(BundledDotnetTool.Version)]" />
  </ItemGroup>

  <Target Name="ValidateBundledDotnetToolRuntimeIdentifiers"
          DependsOnTargets="PublishRuntimeIdentifierGraphFiles"
          Condition="'@(BundledDotnetTool)' != '' and '$(DotnetUserSecretsPackageRid)' != ''">
    <PickBestRid Condition="'%(BundledDotnetTool.RidSpecificPackageId)' != ''"
                 RuntimeGraphPath="$(OutputPath)RuntimeIdentifierGraph.json"
                 TargetRid="$(ProductMonikerRid)"
                 SupportedRids="%(BundledDotnetTool.RidSpecificPackageRuntimeIdentifiers)">
      <Output TaskParameter="MatchingRid" PropertyName="_MatchingBundledDotnetToolRid" />
    </PickBestRid>

    <Error Condition="'%(BundledDotnetTool.RidSpecificPackageId)' != '' and '$(_MatchingBundledDotnetToolRid)' != '$(DotnetUserSecretsPackageRid)'"
           Text="Package '%(BundledDotnetTool.Identity)' resolved RID-specific package '%(BundledDotnetTool.RidSpecificPackageId)', but the runtime graph selected '$(_MatchingBundledDotnetToolRid)' for target RID '$(ProductMonikerRid)'." />
  </Target>

  <Target Name="LayoutBundledTools"
          DependsOnTargets="ValidateBundledDotnetToolRuntimeIdentifiers"
          Condition="'@(BundledDotnetTool)' != ''">
    <ItemGroup>
      <BundledToolFiles Include="%(BundledDotnetTool.RestoredPackagePath)\**\*.*" PackageToRestore="%(BundledDotnetTool.Identity)" PackageVersionToRestore="%(BundledDotnetTool.Version)" />
      <BundledToolFiles Remove="%(BundledDotnetTool.RestoredPackagePath)\*.*" />
    </ItemGroup>

    <Copy SourceFiles="@(BundledToolFiles)"
          DestinationFiles="@(BundledToolFiles->'$(OutputPath)DotnetTools\%(PackageToRestore)\%(PackageVersionToRestore)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

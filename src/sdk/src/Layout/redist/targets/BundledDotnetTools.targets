<Project>

  <UsingTask TaskName="Microsoft.NET.Build.Tasks.SelectRuntimeIdentifierSpecificItems" AssemblyFile="$(MicrosoftNETBuildTasksAssembly)" />

  <PropertyGroup>
    <DotnetUserSecretsPackageRids>linux-x64;linux-arm;linux-arm64;win-x64;win-x86;win-arm64;osx-x64;osx-arm64</DotnetUserSecretsPackageRids>
  </PropertyGroup>

  <ItemGroup Condition="'$(IncludeAspNetCoreRuntime)' != 'false'">
    <BundledDotnetTool Include="dotnet-dev-certs" Version="$(DotnetDevCertsPackageVersion)" />
    <BundledDotnetTool Include="dotnet-user-jwts" Version="$(DotnetUserJwtsPackageVersion)" />
    <BundledDotnetTool Include="dotnet-user-secrets" Version="$(DotnetUserSecretsPackageVersion)" ObsoletesCliTool="Microsoft.Extensions.SecretManager.Tools" />
  </ItemGroup>

  <ItemGroup>
    <BundledDotnetTool Update="@(BundledDotnetTool)">
      <PackagePathRelativeToPackageRoot>%(Identity)/%(Version)/</PackagePathRelativeToPackageRoot>
      <NupkgPathRelativeToPackageRoot>%(Identity)/%(Version)/%(Identity).%(Version).nupkg</NupkgPathRelativeToPackageRoot>
    </BundledDotnetTool>
  </ItemGroup>

  <ItemGroup>
    <BundledDotnetTool Update="@(BundledDotnetTool)">
      <RestoredPackagePath>$(NuGetPackageRoot)$([MSBuild]::ValueOrDefault('%(PackagePathRelativeToPackageRoot)', '').ToLowerInvariant())/</RestoredPackagePath>
      <RestoredNupkgPath>$(NuGetPackageRoot)$([MSBuild]::ValueOrDefault('%(NupkgPathRelativeToPackageRoot)', '').ToLowerInvariant())</RestoredNupkgPath>
    </BundledDotnetTool>
  </ItemGroup>

  <Target Name="SelectBundledDotnetToolPackages"
          Condition="'@(BundledDotnetTool)' != ''">
    <ItemGroup>
      <_DotnetUserSecretsPackageRid Include="$(DotnetUserSecretsPackageRids)" Condition="'$(DotNetBuildSourceOnly)' != 'true'" />
      <_DotnetUserSecretsRidSpecificPackage Include="@(_DotnetUserSecretsPackageRid)">
        <PackageId>dotnet-user-secrets.%(_DotnetUserSecretsPackageRid.Identity)</PackageId>
        <PackageVersion>$(DotnetUserSecretsPackageVersion)</PackageVersion>
        <RuntimeIdentifier>%(_DotnetUserSecretsPackageRid.Identity)</RuntimeIdentifier>
      </_DotnetUserSecretsRidSpecificPackage>
    </ItemGroup>

    <SelectRuntimeIdentifierSpecificItems Condition="'@(_DotnetUserSecretsRidSpecificPackage)' != ''"
                                          TargetRuntimeIdentifier="$(ProductMonikerRid)"
                                          Items="@(_DotnetUserSecretsRidSpecificPackage)"
                                          RuntimeIdentifierGraphPath="$(RuntimeIdentifierGraphPath)">
      <Output TaskParameter="SelectedItems" ItemName="_SelectedDotnetUserSecretsPackage" />
    </SelectRuntimeIdentifierSpecificItems>

    <ItemGroup Condition="'@(_SelectedDotnetUserSecretsPackage)' == ''">
      <_SelectedDotnetUserSecretsPackage Include="dotnet-user-secrets">
        <PackageId>dotnet-user-secrets</PackageId>
        <PackageVersion>$(DotnetUserSecretsPackageVersion)</PackageVersion>
      </_SelectedDotnetUserSecretsPackage>
    </ItemGroup>

    <PropertyGroup>
      <_DotnetUserSecretsPackageId>@(_SelectedDotnetUserSecretsPackage->'%(PackageId)')</_DotnetUserSecretsPackageId>
    </PropertyGroup>

    <PropertyGroup>
      <_DotnetUserSecretsPackageVersion>@(_SelectedDotnetUserSecretsPackage->'%(PackageVersion)')</_DotnetUserSecretsPackageVersion>
      <_DotnetUserSecretsRestoredPackagePath>$(NuGetPackageRoot)$(_DotnetUserSecretsPackageId.ToLowerInvariant())/$(_DotnetUserSecretsPackageVersion)/</_DotnetUserSecretsRestoredPackagePath>
    </PropertyGroup>
  </Target>

  <Target Name="AddBundledDotnetToolsAsPackageDownloads"
          BeforeTargets="CollectPackageDownloads"
          DependsOnTargets="SelectBundledDotnetToolPackages"
          Condition="'$(IncludeAspNetCoreRuntime)' != 'false'">
    <ItemGroup>
      <PackageDownload Include="dotnet-dev-certs" Version="[$(DotnetDevCertsPackageVersion)]" />
      <PackageDownload Include="dotnet-user-jwts" Version="[$(DotnetUserJwtsPackageVersion)]" />
      <PackageDownload Include="%(_SelectedDotnetUserSecretsPackage.PackageId)" Version="[%(_SelectedDotnetUserSecretsPackage.PackageVersion)]" />
    </ItemGroup>
  </Target>

  <Target Name="LayoutBundledTools"
          DependsOnTargets="SelectBundledDotnetToolPackages"
          Condition="'@(BundledDotnetTool)' != ''">
    <ItemGroup>
      <_BundledDotnetToolToLayout Include="@(BundledDotnetTool)" Condition="'%(BundledDotnetTool.Identity)' != 'dotnet-user-secrets'" />
      <BundledToolFiles Include="%(_BundledDotnetToolToLayout.RestoredPackagePath)\**\*.*" PackageToRestore="%(_BundledDotnetToolToLayout.Identity)" PackageVersionToRestore="%(_BundledDotnetToolToLayout.Version)" />
      <BundledToolFiles Include="$(_DotnetUserSecretsRestoredPackagePath)\**\*.*" PackageToRestore="dotnet-user-secrets" PackageVersionToRestore="$(_DotnetUserSecretsPackageVersion)" />
      <BundledToolFiles Remove="%(_BundledDotnetToolToLayout.RestoredPackagePath)\*.*" />
      <BundledToolFiles Remove="$(_DotnetUserSecretsRestoredPackagePath)\*.*" />
    </ItemGroup>

    <Copy SourceFiles="@(BundledToolFiles)"
          DestinationFiles="@(BundledToolFiles->'$(OutputPath)DotnetTools\%(PackageToRestore)\%(PackageVersionToRestore)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

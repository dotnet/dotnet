<Project>
  <!--
    Inject SCCSID in AOT apps which we include in libcoreclr and other runtime native libs.
    Keep in sync with arcade's Microsoft.DotNet.Build.Tasks.Packaging/src/build/Packaging.targets
  -->
  <Target Name="AddSccsidMetadata"
          DependsOnTargets="GetAssemblyVersion;InitializeSourceControlInformation"
          BeforeTargets="BeforeCompile">
    <ItemGroup>
      <AssemblyMetadata Include="sccsid" Value="@(#)Version $(FileVersion) @Commit: $(SourceRevisionId)" />
    </ItemGroup>
  </Target>
</Project>

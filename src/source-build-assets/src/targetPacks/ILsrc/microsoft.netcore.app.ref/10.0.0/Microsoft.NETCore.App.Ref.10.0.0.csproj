<Project Sdk="Microsoft.Build.NoTargets">

  <PropertyGroup>
    <PackageId>Microsoft.NETCore.App.Ref</PackageId>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <PackageVersion>10.0.0</PackageVersion>
    <AssemblyName>Microsoft.NETCore.App.Ref</AssemblyName>
    <BuildOutputTargetFolder>ref</BuildOutputTargetFolder>
    <Serviceable>true</Serviceable>
    <Description>Internal implementation package not meant for direct consumption. Please do not reference directly. 
A set of .NET APIs that are included in the default .NET application model. Contains reference assemblies, documentation, and other design-time assets.</Description>
    <PackageProjectUrl>https://dot.net/</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>https://go.microsoft.com/fwlink/?LinkID=799421</PackageReleaseNotes>
    <PackageType>DotnetPlatform</PackageType>
  </PropertyGroup>

  <ItemGroup>
    <None Include="data/FrameworkList.xml" Pack="true" PackagePath="data" />
    <None Include="data/PackageOverrides.txt" Pack="true" PackagePath="data" />
    <None Include="data/PlatformManifest.txt" Pack="true" PackagePath="data" />
    <None Include="LICENSE.TXT" Pack="true" PackagePath="" />
    <None Include="Microsoft.NETCore.App.versions.txt" Pack="true" PackagePath="" />
    <None Include="THIRD-PARTY-NOTICES.TXT" Pack="true" PackagePath="" />
    <None Include="useSharedDesignerContext.txt" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>

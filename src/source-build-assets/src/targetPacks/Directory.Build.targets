<Project>

  <Import Project="..\..\Directory.Build.targets" />
  <Import Project="$(RepositoryEngineeringDir)ILTooling.targets" />

  <!-- Targeting packs assemble their .il sources directly into $(BaseOutputPath)pack/ in the
       final package layout. UseLocalTargetingPack in src/referencePackages/Directory.Build.targets
       reads this exact location via:
         <ResolvedTargetingPack Path="$(ArtifactsBinDir)<id>.<ver>/pack" />
         <ResolvedFrameworkReference TargetingPackPath="$(ArtifactsBinDir)<name>.<ver>/pack" />
       so reference packages compile against the freshly-built local target packs instead of any
       SDK-bundled ones. The historical eng/ManualNuspec.targets file populated the same location.
       The static on-disk content (LICENSE.TXT, build/<tfm>/*.targets, data/FrameworkList.xml, etc.)
       is staged into the same directory by _StageTargetingPackLayout. -->
  <PropertyGroup>
    <_TargetingPackLayoutDir>$(BaseOutputPath)pack\</_TargetingPackLayoutDir>
  </PropertyGroup>

  <ItemGroup Condition="'$(UsingMicrosoftTraversalSdk)' != 'true'">
    <_TargetingPackIlSrc Include="$(MSBuildProjectDirectory)\**\*.il" />
    <_TargetingPackIlSrc Update="@(_TargetingPackIlSrc)" OutputFile="$(_TargetingPackLayoutDir)%(RecursiveDir)%(Filename).dll" />
  </ItemGroup>

  <Target Name="BuildTargetingPackIlSrc"
          BeforeTargets="GenerateNuspec"
          Inputs="@(_TargetingPackIlSrc)"
          Outputs="@(_TargetingPackIlSrc->'%(OutputFile)')"
          DependsOnTargets="ResolveIlToolPaths"
          Condition="'@(_TargetingPackIlSrc)' != ''">
    <Message Importance="High" Text="[$([System.DateTime]::Now.ToString('HH:mm:ss.ff'))] Begin $(MSBuildProjectName) -> $(_TargetingPackLayoutDir)..." />
    <MakeDir Directories="@(_TargetingPackIlSrc->'$(_TargetingPackLayoutDir)%(RecursiveDir)')" />

    <ItemGroup>
      <_IndividualFileProject Include="$(MSBuildProjectFullPath)"
                              Properties="IlFile=%(_TargetingPackIlSrc.Identity);OutputFile=%(_TargetingPackIlSrc.OutputFile)" />
    </ItemGroup>

    <MSBuild Projects="@(_IndividualFileProject)"
             Targets="BuildIlFile"
             BuildInParallel="true"
             StopOnFirstFailure="true" />

    <Message Importance="High" Text="[$([System.DateTime]::Now.ToString('HH:mm:ss.ff'))] $(MSBuildProjectName) -> $(_TargetingPackLayoutDir) DONE" />
  </Target>

  <Target Name="BuildIlFile" DependsOnTargets="ResolveIlToolPaths">
    <Error Condition="'$(IlasmPath)' == ''" Text="The 'IlasmPath' property must be set." />

    <Exec Command="$(IlasmPath) $(IlFile) -dll -quiet -nologo &quot;-output=$(OutputFile)&quot;"
          IgnoreStandardErrorWarningFormat="true"
          CustomErrorRegularExpression=": error : " />
  </Target>

  <!-- Surface the assembled DLLs as <None Pack="true"> items at the same relative path
       inside the package as their .il counterpart sits on disk (e.g. ref/net6.0/X.il
       becomes ref/net6.0/X.dll in the package). -->
  <Target Name="_AddTargetingPackDllsToPack"
          BeforeTargets="_GetPackageFiles"
          DependsOnTargets="BuildTargetingPackIlSrc"
          Condition="'@(_TargetingPackIlSrc)' != ''">
    <ItemGroup>
      <None Include="@(_TargetingPackIlSrc->'%(OutputFile)')"
            Pack="true"
            PackagePath="%(_TargetingPackIlSrc.RecursiveDir)" />
    </ItemGroup>
  </Target>

  <!-- Stage the static on-disk content (LICENSE.TXT, build/<tfm>/*.targets, data/*.xml, etc.)
       alongside the ilasm-produced DLLs in $(BaseOutputPath)pack/. -->
  <Target Name="_StageTargetingPackLayout"
          AfterTargets="Pack"
          Condition="'@(_TargetingPackIlSrc)' != ''">
    <ItemGroup>
      <_TargetingPackStaticContent Include="$(MSBuildProjectDirectory)\**\*.*"
                                   Exclude="$(MSBuildProjectDirectory)\**\*.il;
                                            $(MSBuildProjectDirectory)\**\*.csproj;
                                            $(MSBuildProjectDirectory)\**\$(CustomizationsPropsFile);
                                            $(MSBuildProjectDirectory)\**\$(CustomizationsSourceFile)" />
    </ItemGroup>

    <Copy SourceFiles="@(_TargetingPackStaticContent)"
          DestinationFiles="@(_TargetingPackStaticContent->'$(_TargetingPackLayoutDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

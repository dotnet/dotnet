<!--
  Validation metadata for the newtonsoft-json component. Imported by newtonsoft-json.proj at
  build time and loaded standalone by UpdateExternalMetadata and ExternalPackageTests.

  This file deliberately declares no SDK and has no upward import chain so it can be loaded
  with plain `new Project(filePath, …)` in any host — including inside `dotnet test`, where
  MSBuildLocator cannot register because the test platform pre-loads Microsoft.Build.
-->
<Project>

  <Import Project="$(MSBuildThisFileDirectory)validation.props" />

  <PropertyGroup>
    <!-- The upstream build computes a date-based FileVersion revision via PowerShell
         (GetVersion in build.ps1). Set it here to match the official NuGet package.
         See https://github.com/dotnet/source-build/issues/5511 -->
    <FileVersionRevision>30916</FileVersionRevision>
  </PropertyGroup>

  <ItemGroup>
    <FileVersionValidationPackage Include="Newtonsoft.Json" />
  </ItemGroup>

</Project>

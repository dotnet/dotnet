<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>NuGet.DependencyResolver.Core</PackageId>
    <TargetFrameworks>net8.0;netstandard2.0</TargetFrameworks>
    <PackageVersion>6.14.0</PackageVersion>
    <AssemblyName>NuGet.DependencyResolver.Core</AssemblyName>
    <StrongNameKeyId>MicrosoftShared</StrongNameKeyId>
    <Description>NuGet's PackageReference dependency resolver implementation.</Description>
    <PackageProjectUrl>https://aka.ms/nugetprj</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>nuget</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <ProjectReference Include="../../nuget.configuration/6.14.0/NuGet.Configuration.6.14.0.csproj" />
    <ProjectReference Include="../../nuget.librarymodel/6.14.0/NuGet.LibraryModel.6.14.0.csproj" />
    <ProjectReference Include="../../nuget.protocol/6.14.0/NuGet.Protocol.6.14.0.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../nuget.configuration/6.14.0/NuGet.Configuration.6.14.0.csproj" />
    <ProjectReference Include="../../nuget.librarymodel/6.14.0/NuGet.LibraryModel.6.14.0.csproj" />
    <ProjectReference Include="../../nuget.protocol/6.14.0/NuGet.Protocol.6.14.0.csproj" />
  </ItemGroup>

</Project>

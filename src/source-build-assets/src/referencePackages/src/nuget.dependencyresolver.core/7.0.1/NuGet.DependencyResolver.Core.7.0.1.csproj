<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>NuGet.DependencyResolver.Core</PackageId>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <PackageVersion>7.0.1</PackageVersion>
    <AssemblyName>NuGet.DependencyResolver.Core</AssemblyName>
    <StrongNameKeyId>MicrosoftShared</StrongNameKeyId>
    <Description>NuGet's PackageReference dependency resolver implementation.</Description>
    <PackageProjectUrl>https://aka.ms/nugetprj</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>nuget</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <ProjectReference Include="../../nuget.configuration/7.0.1/NuGet.Configuration.7.0.1.csproj" />
    <ProjectReference Include="../../nuget.librarymodel/7.0.1/NuGet.LibraryModel.7.0.1.csproj" />
    <ProjectReference Include="../../nuget.protocol/7.0.1/NuGet.Protocol.7.0.1.csproj" />
  </ItemGroup>

</Project>

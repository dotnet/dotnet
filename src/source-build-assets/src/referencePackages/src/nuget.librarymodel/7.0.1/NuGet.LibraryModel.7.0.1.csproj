<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>NuGet.LibraryModel</PackageId>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <PackageVersion>7.0.1</PackageVersion>
    <AssemblyName>NuGet.LibraryModel</AssemblyName>
    <StrongNameKeyId>MicrosoftShared</StrongNameKeyId>
    <Description>NuGet's types and interfaces for understanding dependencies.</Description>
    <PackageProjectUrl>https://aka.ms/nugetprj</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>nuget</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <ProjectReference Include="../../nuget.common/7.0.1/NuGet.Common.7.0.1.csproj" />
    <ProjectReference Include="../../nuget.versioning/7.0.1/NuGet.Versioning.7.0.1.csproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>System.Formats.Nrbf</PackageId>
    <TargetFrameworks>net10.0;net8.0;net9.0;netstandard2.0</TargetFrameworks>
    <PackageVersion>10.0.3</PackageVersion>
    <AssemblyName>System.Formats.Nrbf</AssemblyName>
    <StrongNameKeyId>Open</StrongNameKeyId>
    <Description>Provides a safe reader for .NET Remoting Binary Format (NRBF) payloads.</Description>
    <PackageProjectUrl>https://dot.net/</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>https://go.microsoft.com/fwlink/?LinkID=799421</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <ProjectReference Include="../../system.reflection.metadata/10.0.3/System.Reflection.Metadata.10.0.3.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <ProjectReference Include="../../system.reflection.metadata/10.0.3/System.Reflection.Metadata.10.0.3.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../system.reflection.metadata/10.0.3/System.Reflection.Metadata.10.0.3.csproj" />
    <ProjectReference Include="../../microsoft.bcl.hashcode/6.0.0/Microsoft.Bcl.HashCode.6.0.0.csproj" />
  </ItemGroup>

</Project>

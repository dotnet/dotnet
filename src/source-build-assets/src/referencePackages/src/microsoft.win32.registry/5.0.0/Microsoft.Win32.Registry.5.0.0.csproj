<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Microsoft.Win32.Registry</PackageId>
    <TargetFrameworks>netstandard2.0</TargetFrameworks>
    <PackageVersion>5.0.0</PackageVersion>
    <AssemblyName>Microsoft.Win32.Registry</AssemblyName>
    <BuildOutputTargetFolder>ref</BuildOutputTargetFolder>
    <Description>Provides support for accessing and modifying the Windows Registry.

Commonly Used Types:
Microsoft.Win32.RegistryKey
Microsoft.Win32.Registry
Microsoft.Win32.RegistryValueKind
Microsoft.Win32.RegistryHive
Microsoft.Win32.RegistryView
 
When using NuGet 3.x this package requires at least version 3.4.</Description>
    <Title>Microsoft.Win32.Registry</Title>
    <PackageProjectUrl>https://github.com/dotnet/runtime</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>https://go.microsoft.com/fwlink/?LinkID=799421</PackageReleaseNotes>
    <MinClientVersion>2.12</MinClientVersion>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../system.buffers/4.5.1/System.Buffers.4.5.1.csproj" />
    <ProjectReference Include="../../system.memory/4.5.4/System.Memory.4.5.4.csproj" />
    <ProjectReference Include="../../system.security.accesscontrol/5.0.0/System.Security.AccessControl.5.0.0.csproj" />
    <ProjectReference Include="../../system.security.principal.windows/5.0.0/System.Security.Principal.Windows.5.0.0.csproj" />
  </ItemGroup>

</Project>

<Project>

  <PropertyGroup>
    <!-- TextEncoder declares abstract members with unsafe pointer signatures (e.g.
         FindFirstCharacterToEncode(char*, int)) that are marked [CLSCompliant(false)].
         Because the assembly is [CLSCompliant(true)], the compiler reports CS3011
         ("only CLS-compliant members can be abstract"), which is promoted to an error
         under TreatWarningsAsErrors. This mirrors the upstream reference assembly, so
         suppress the diagnostic. -->
    <NoWarn>$(NoWarn);CS3011</NoWarn>
  </PropertyGroup>

</Project>

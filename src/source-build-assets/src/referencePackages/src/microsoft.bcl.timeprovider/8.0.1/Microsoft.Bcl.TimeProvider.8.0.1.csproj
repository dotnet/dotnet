<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Microsoft.Bcl.TimeProvider</PackageId>
    <TargetFrameworks>net8.0;netstandard2.0</TargetFrameworks>
    <PackageVersion>8.0.1</PackageVersion>
    <AssemblyName>Microsoft.Bcl.TimeProvider</AssemblyName>
    <StrongNameKeyId>Open</StrongNameKeyId>
    <Description>Provides support for system time abstraction primitives for .NET Framework and .NET Standard.

Commonly Used Types:
System.TimeProvider
System.ITimer</Description>
    <PackageProjectUrl>https://dot.net/</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>https://go.microsoft.com/fwlink/?LinkID=799421</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../microsoft.bcl.asyncinterfaces/8.0.0/Microsoft.Bcl.AsyncInterfaces.8.0.0.csproj" />
  </ItemGroup>

</Project>

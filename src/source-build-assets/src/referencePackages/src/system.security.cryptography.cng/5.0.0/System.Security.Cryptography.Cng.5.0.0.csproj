<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>System.Security.Cryptography.Cng</PackageId>
    <TargetFrameworks>netstandard2.0;netstandard2.1</TargetFrameworks>
    <PackageVersion>5.0.0</PackageVersion>
    <AssemblyName>System.Security.Cryptography.Cng</AssemblyName>
    <BuildOutputTargetFolder>ref</BuildOutputTargetFolder>
    <Description>Provides cryptographic algorithm implementations and key management with Windows Cryptographic Next Generation API (CNG).

Commonly Used Types:
System.Security.Cryptography.RSACng
System.Security.Cryptography.ECDsaCng
System.Security.Cryptography.CngKey
 
When using NuGet 3.x this package requires at least version 3.4.</Description>
    <Title>System.Security.Cryptography.Cng</Title>
    <PackageProjectUrl>https://github.com/dotnet/runtime</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>https://go.microsoft.com/fwlink/?LinkID=799421</PackageReleaseNotes>
    <MinClientVersion>2.12</MinClientVersion>
  </PropertyGroup>

</Project>

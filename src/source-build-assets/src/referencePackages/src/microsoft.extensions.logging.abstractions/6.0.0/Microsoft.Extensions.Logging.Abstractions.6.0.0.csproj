  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../system.buffers/4.5.1/System.Buffers.4.5.1.csproj" />
    <ProjectReference Include="../../system.memory/4.5.4/System.Memory.4.5.4.csproj" />

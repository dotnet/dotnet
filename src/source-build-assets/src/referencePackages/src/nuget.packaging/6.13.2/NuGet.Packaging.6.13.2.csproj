<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>NuGet.Packaging</PackageId>
    <TargetFrameworks>net8.0;netstandard2.0</TargetFrameworks>
    <PackageVersion>6.13.2</PackageVersion>
    <AssemblyName>NuGet.Packaging</AssemblyName>
    <StrongNameKeyId>MicrosoftShared</StrongNameKeyId>
    <Description>NuGet's understanding of packages. Reading nuspec, nupkgs and package signing.</Description>
    <PackageProjectUrl>https://aka.ms/nugetprj</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>nuget</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <!-- Upgraded from 13.0.3 to 13.0.4 to align with the version built by source-build-assets -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <ProjectReference Include="../../nuget.configuration/6.13.2/NuGet.Configuration.6.13.2.csproj" />
    <ProjectReference Include="../../nuget.versioning/6.13.2/NuGet.Versioning.6.13.2.csproj" />
    <ProjectReference Include="../../system.formats.asn1/8.0.1/System.Formats.Asn1.8.0.1.csproj" />
    <ProjectReference Include="../../system.security.cryptography.pkcs/6.0.4/System.Security.Cryptography.Pkcs.6.0.4.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <!-- Upgraded from 13.0.3 to 13.0.4 to align with the version built by source-build-assets -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <ProjectReference Include="../../nuget.configuration/6.13.2/NuGet.Configuration.6.13.2.csproj" />
    <ProjectReference Include="../../nuget.versioning/6.13.2/NuGet.Versioning.6.13.2.csproj" />
    <ProjectReference Include="../../system.formats.asn1/8.0.1/System.Formats.Asn1.8.0.1.csproj" />
    <ProjectReference Include="../../system.security.cryptography.pkcs/6.0.4/System.Security.Cryptography.Pkcs.6.0.4.csproj" />
    <ProjectReference Include="../../system.text.json/8.0.5/System.Text.Json.8.0.5.csproj" />
  </ItemGroup>

</Project>

<Project>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <!-- The generator omits this dependency, but the netstandard2.0 reference assembly forwards
         Microsoft.Win32.RegistryHive/RegistryView to Microsoft.Win32.Registry, so the reference is
         required to compile (CS1069). The net10.0 target gets these types from the shared framework. -->
    <ProjectReference Include="../../microsoft.win32.registry/5.0.0/Microsoft.Win32.Registry.5.0.0.csproj" />
  </ItemGroup>

</Project>

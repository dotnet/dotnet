<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>NuGet.Configuration</PackageId>
    <TargetFrameworks>netstandard2.0</TargetFrameworks>
    <PackageVersion>6.14.0</PackageVersion>
    <AssemblyName>NuGet.Configuration</AssemblyName>
    <StrongNameKeyId>MicrosoftShared</StrongNameKeyId>
    <Description>NuGet's configuration settings implementation.</Description>
    <PackageProjectUrl>https://aka.ms/nugetprj</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageTags>nuget</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../nuget.common/6.14.0/NuGet.Common.6.14.0.csproj" />
    <ProjectReference Include="../../system.security.cryptography.protecteddata/4.4.0/System.Security.Cryptography.ProtectedData.4.4.0.csproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Microsoft.NET.StringTools</PackageId>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <PackageVersion>18.6.3</PackageVersion>
    <AssemblyName>Microsoft.NET.StringTools</AssemblyName>
    <BuildOutputTargetFolder>ref</BuildOutputTargetFolder>
    <Description>This package contains the Microsoft.NET.StringTools assembly which implements common string-related functionality such as weak interning.</Description>
    <PackageProjectUrl>http://go.microsoft.com/fwlink/?LinkId=624683</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>MSBuild</PackageTags>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ProjectReference Include="../../system.memory/4.6.3/System.Memory.4.6.3.csproj" />
    <ProjectReference Include="../../system.runtime.compilerservices.unsafe/6.1.2/System.Runtime.CompilerServices.Unsafe.6.1.2.csproj" />
  </ItemGroup>

</Project>

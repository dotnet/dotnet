<Project>

  <Import Project="Version.Details.props" />

  <PropertyGroup>
    <MajorVersion>11</MajorVersion>
    <MinorVersion>0</MinorVersion>
    <PatchVersion>0</PatchVersion>
    <SkipPackagePublishingVersionChecks>true</SkipPackagePublishingVersionChecks>

    <!-- Arcade features -->
    <UsingToolXliff>false</UsingToolXliff>
  </PropertyGroup>

  <!-- External package versions -->
  <PropertyGroup>
    <!-- Update whenever the bootstrap version changes. Can't use the release version here
         as external packages (which includes newtonsoft.json) build last. -->
    <NewtonsoftJsonBootstrapVersion>13.0.4</NewtonsoftJsonBootstrapVersion>

    <Antlr4Version>4.13.1</Antlr4Version>
    <AzureActiveDirectoryIdentityModelExtensionsForDotNetReleaseVersion>8.0.1</AzureActiveDirectoryIdentityModelExtensionsForDotNetReleaseVersion>
    <CssParserReleaseVersionSuffix>20230414.1</CssParserReleaseVersionSuffix>
    <HumanizerReleaseVersion>2.14.1</HumanizerReleaseVersion>
    <MSBuildLocatorReleaseVersion>1.10.2</MSBuildLocatorReleaseVersion>
    <NewtonsoftJsonReleaseVersion>13.0.4</NewtonsoftJsonReleaseVersion>
    <VsSolutionPersistenceReleaseVersion>1.0.52</VsSolutionPersistenceReleaseVersion>
    <SpectreConsoleReleaseVersion>0.54.0</SpectreConsoleReleaseVersion>
    <OpenTelemetryDotNetReleaseVersion>1.16.0</OpenTelemetryDotNetReleaseVersion>
    <OpenTelemetryDotNetContribHttpReleaseVersion>1.16.0</OpenTelemetryDotNetContribHttpReleaseVersion>
    <OpenTelemetryDotNetContribRuntimeReleaseVersion>1.15.1</OpenTelemetryDotNetContribRuntimeReleaseVersion>
    <OpenTelemetryDotNetContribPersistentStorageAbstractionsReleaseVersion>1.1.0</OpenTelemetryDotNetContribPersistentStorageAbstractionsReleaseVersion>
    <OpenTelemetryDotNetContribPersistentStorageFileSystemReleaseVersion>1.1.0</OpenTelemetryDotNetContribPersistentStorageFileSystemReleaseVersion>
  </PropertyGroup>

  <PropertyGroup>
    <!-- NuGet dependencies -->
    <NuGetPackagingVersion>6.11.2</NuGetPackagingVersion>
    <!-- xUnit dependencies -->
    <XunitSkippableFactVersion>1.4.13</XunitSkippableFactVersion>
  </PropertyGroup>

</Project>

<Project>

  <!-- Package validation: compare built packages against their upstream NuGet baseline to ensure
       API surface compatibility. Disabled when building from the VMR since upstream feeds aren't
       available in that environment. -->
  <PropertyGroup Condition="'$(DotNetBuildFromVMR)' != 'true' and '$(IsPackable)' == 'true'">
    <EnablePackageValidation>true</EnablePackageValidation>
    <PackageValidationBaselineVersion>$(PackageVersion)</PackageValidationBaselineVersion>
    <EnableStrictModeForBaselineValidation>true</EnableStrictModeForBaselineValidation>
    <!-- Only validate against the baseline package; don't check cross-TFM compatibility
         within the package itself — that's not a concern for source-build. -->
    <EnableStrictModeForCompatibleTfms>false</EnableStrictModeForCompatibleTfms>
    <EnableStrictModeForCompatibleFrameworksInPackage>false</EnableStrictModeForCompatibleFrameworksInPackage>
    <!-- PKV004: "TFM does not have a compatible runtime asset in the package."
         Reference packages and targeting packs only ship ref/ assemblies by design;
         they never contain lib/ (runtime) assets. -->
    <NoWarn>$(NoWarn);PKV004</NoWarn>
  </PropertyGroup>

</Project>

    <None Include="$(OutputPath)netstandard2.0\Microsoft.Extensions.FileSystemGlobbing.dll" Pack="true" PackagePath="tools\net8.0\Microsoft.Extensions.FileSystemGlobbing.dll" />
    <None Include="$(OutputPath)netstandard2.0\Microsoft.CodeCoverage.IO\Microsoft.CodeCoverage.IO.dll" Pack="true" PackagePath="tools\net8.0\Microsoft.CodeCoverage.IO.dll" />
    <None Include="$(OutputPath)netstandard2.0\Microsoft.CodeCoverage.IO\cs\Microsoft.CodeCoverage.IO.resources.dll" Pack="true" PackagePath="tools\net8.0\cs\Microsoft.CodeCoverage.IO.dll" />
    <None Include="$(OutputPath)netstandard2.0\Microsoft.CodeCoverage.IO\de\Microsoft.CodeCoverage.IO.resources.dll" Pack="true" PackagePath="tools\net8.0\de\Microsoft.CodeCoverage.IO.dll" />

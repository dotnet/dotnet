<?xml version="1.0" encoding="utf-8"?>
<Project>
  <Import Project="Sdk.props" Sdk="Microsoft.DotNet.Arcade.Sdk" />

  <PropertyGroup>
    <!-- Emsdk doesn't support Arcade-driven target framework filtering. -->
    <NoTargetFrameworkFiltering>true</NoTargetFrameworkFiltering>
  </PropertyGroup>

  <PropertyGroup Condition="'$(DotNetFinalVersionKind)' == 'release'">
    <StableVersion>$(VersionPrefix)</StableVersion>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Initialize build architecture and OS -->
    <BuildArchitecture Condition="'$(BuildArchitecture)' == ''">$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture.ToString().ToLowerInvariant)</BuildArchitecture>

    <BuildOS Condition="'$(BuildOS)' == '' and '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'true'">linux</BuildOS>
    <BuildOS Condition="'$(BuildOS)' == '' and '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'true'">osx</BuildOS>
    <BuildOS Condition="'$(BuildOS)' == '' and '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Windows)))' == 'true'">windows</BuildOS>

    <BuildRid Condition="'$(BuildRid)' == ''">$(BuildOS)-$(BuildArchitecture)</BuildRid>
    <BuildRid Condition="'$(BuildRid)' == '' and '$(BuildOS)' == 'windows'">win-$(BuildArchitecture)</BuildRid>

    <!-- Initialize target architecture and OS -->
    <TargetArchitecture Condition="'$(TargetArchitecture)' == ''">$(BuildArchitecture)</TargetArchitecture>
    <TargetOS Condition="'$(TargetOS)' == ''">$(BuildOS)</TargetOS>
    <TargetRid Condition="'$(TargetRid)' == ''">$(BuildRid)</TargetRid>
  </PropertyGroup>

    <!-- Common properties -->
  <PropertyGroup>

    <__ProjectDir Condition="'$(__ProjectDir)'==''">$(MSBuildThisFileDirectory)</__ProjectDir>
    <ProjectDir>$(__ProjectDir)\</ProjectDir>
    <RootRepoDir>$(ProjectDir)</RootRepoDir>
    <ProjectDir Condition="'$(__ProjectDir)'==''">$(MSBuildThisFileDirectory)</ProjectDir>

    <BaseIntermediateOutputPath>$(RootRepoDir)artifacts\obj\$(PlatformConfigPathPart)\</BaseIntermediateOutputPath>

    <SourceDir>$(__SourceDir)\</SourceDir>
    <SourceDir Condition="'$(__SourceDir)'==''">$(ProjectDir)src\</SourceDir>

    <RootBinDir>$(__RootBinDir)\</RootBinDir>
    <RootBinDir Condition="'$(__RootBinDir)'==''">$(RootRepoDir)artifacts\</RootBinDir>

    <BinDir>$(__BinDir)\</BinDir>
    <BinDir Condition="'$(__BinDir)'==''">$(RootBinDir)bin\$(PlatformConfigPathPart)\</BinDir>
  </PropertyGroup>

  <PropertyGroup>
    <BinaryenDir>$(ProjectDir)\binaryen\dotnet</BinaryenDir>
    <BuildBinaryenDir Condition="'$(TargetRid)' == '$(BuildRid)'">$(BinaryenDir)</BuildBinaryenDir>
    <BuildBinaryenDir Condition="'$(TargetRid)' != '$(BuildRid)'">$(BaseIntermediateOutputPath)\build\binaryen\$(BuildRid)</BuildBinaryenDir>
    <NodeDir>$(ProjectDir)\node\dotnet</NodeDir>
    <BuildNodeDir Condition="'$(TargetRid)' == '$(BuildRid)'">$(NodeDir)</BuildNodeDir>
    <BuildNodeDir Condition="'$(TargetRid)' != '$(BuildRid)'">$(BaseIntermediateOutputPath)\build\node\$(BuildRid)</BuildNodeDir>
    <PythonDir>$(ProjectDir)\python\dotnet</PythonDir>
    <BuildPythonDir Condition="'$(TargetRid)' == '$(BuildRid)'">$(PythonDir)</BuildPythonDir>
    <BuildPythonDir Condition="'$(TargetRid)' != '$(BuildRid)'">$(BaseIntermediateOutputPath)\build\python\$(BuildRid)</BuildPythonDir>
    <LLVMDir>$(ProjectDir)\llvm\dotnet</LLVMDir>
    <BuildLLVMDir Condition="'$(TargetRid)' == '$(BuildRid)'">$(LLVMDir)</BuildLLVMDir>
    <BuildLLVMDir Condition="'$(TargetRid)' != '$(BuildRid)'">$(BaseIntermediateOutputPath)\build\llvm\$(BuildRid)</BuildLLVMDir>
    <EmscriptenDir>$(ProjectDir)\emscripten\dotnet</EmscriptenDir>
  </PropertyGroup>
</Project>
